# ============================================================
# KIDSCART – .gitignore
# ============================================================

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*

# ── Node Modules ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploads (local) ──────────────────────────────────────────
uploads/
public/uploads/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ── Build Output ─────────────────────────────────────────────
dist/
build/
.next/
out/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Coverage & Testing ───────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────
*.tgz
*.zip
.cache/
